{
    "id": "adestio_business_suite",
    "name": "Adestio Business Suite",
    "description": "Gestionale enterprise all-in-one per la simulazione preventivi, fatturazione elettronica XML SDI, anagrafiche, magazzino e punto vendita POS.",
    "icon": "business_center",
    "main": "app.js",
    "color": "#6366F1",
    "version": "1.0.17",
    "author": "NunzioTech",
    "category": "erp",
    "tags": [
        "gestionale",
        "preventivi",
        "fatturazione",
        "magazzino",
        "pos",
        "sdi"
    ],
    "backend": "backend.js",
    "ipc": {
        "namespace": "businessSuite"
    },
    "apis": [
        "anagrafica_persone",
        "anagrafica_aziende",
        "documenti_fiscali"
    ],
