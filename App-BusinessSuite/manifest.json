    "links": [
        {
            "rel": "help",
            "href": "https://adestio.nunziotech.com/docs/business_suite"
        }
    ],
    "licensing": {
        "type": "premium"
    },
    "dependencies": {},
    "permissions": [
        "businessSuite:*",
        "anagrafica:*",
        "datiAzienda:*"
    ]
}